# Copy to .env and fill. .env is gitignored.

# Postgres. Local dev: the Docker container (see README). Prod: Neon (set in Vercel).
DATABASE_URL=postgres://postgres:postgres@localhost:5433/clans

# Bungie dev app — bungie.net/en/Application
BUNGIE_API_KEY=
AUTH_BUNGIE_ID=
AUTH_BUNGIE_SECRET=

# Auth.js cookie signing secret — generate with: npx auth secret
AUTH_SECRET=

# Manual requests only (requests/me.http): session cookie value from the browser.
SESSION_COOKIE=
